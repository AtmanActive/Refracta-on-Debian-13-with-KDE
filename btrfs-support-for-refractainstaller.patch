 # Record errors in a logfile.
 exec 2>"$error_log"
 echo "Version:	$version" >> "$error_log"
+
+# ── Dialog logging ───────────────────────────────────────────────────────────
+# Make it possible to see, from the log alone, exactly WHEN each user-facing
+# dialog was shown, what it was, how the user answered, and how long it stayed
+# open — the raw material for later decoupling the questions from the work.
+#   * log_event  appends one ISO-timestamped, greppable line to $error_log
+#                (grep 'DIALOG' for the decision/wait timeline). xtrace is paused
+#                around the bookkeeping so the markers stay clean.
+#   * yad()      is the single choke point every dialog passes through (nothing
+#                calls yad by full path). It logs an "open" marker before the
+#                dialog and a "close" marker after it — with the button exit code
+#                and how long it was open — WITHOUT disturbing yad's stdout
+#                (callers capture it) or its exit status (callers test $?).
+log_event () {
+	local _was=$-
+	{ set +x ; } 2>/dev/null
+	printf '%s %s\n' "$(_iso_now)" "$*" >> "$error_log"
+	[[ $_was == *x* ]] && set -x
+	return 0
+}
+
+yad () {
+	local _was=$-
+	{ set +x ; } 2>/dev/null
+	local _title="" _kind="dialog" _prev="" _a
+	for _a in "$@" ; do
+		[[ $_prev == "--title" ]] && _title="$_a"
+		case "$_a" in
+			--title=*)   _title="${_a#--title=}" ;;
+			--text-info) _kind="text-info" ;;
+			--list)      _kind="list" ;;
+			--form)      _kind="form" ;;
+			--entry)     _kind="entry" ;;
+			--progress)  _kind="progress" ;;
+			--question)  _kind="question" ;;
+			--info)      _kind="info" ;;
+			--file)      _kind="file" ;;
+		esac
+		_prev="$_a"
+	done
+	[[ -z "$_title" ]] && _title="(untitled)"
+	local _t0=$EPOCHSECONDS
+	printf '%s DIALOG open  kind=%-9s title=%s\n' "$(_iso_now)" "$_kind" "$_title" >> "$error_log"
+	[[ $_was == *x* ]] && set -x
+	command yad "$@"
+	local _rc=$?
+	{ set +x ; } 2>/dev/null
+	printf '%s DIALOG close kind=%-9s title=%s exit=%s duration=%ss\n' \
+		"$(_iso_now)" "$_kind" "$_title" "$_rc" "$(( EPOCHSECONDS - _t0 ))" >> "$error_log"
+	[[ $_was == *x* ]] && set -x
+	return $_rc
+}
+
+log_event "==== refractainstaller-yad (GUI) session start — $version ===="
 #******************************************************************
 
