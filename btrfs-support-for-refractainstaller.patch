+btrfs_layout_manifest=".refracta-btrfs-layout"
+btrfs_subvols=( @rootfs @home @var @tmp @snapshots )
+btrfs_subvol_mounts=( "/" "/home" "/var" "/tmp" "/.snapshots" )
+btrfs_root_subvol="@rootfs"   # the subvolume mounted at "/" (overridden by manifest)
