+# ── Timestamped logging (ISO-8601) ───────────────────────────────────────────
+# Every xtrace line (the bulk of this log) is prefixed with an ISO-8601 timestamp
+# via PS4, so the log shows WHEN each step ran. _iso_now uses bash's builtin
+# printf time format, so it adds no external process per traced line.
+_iso_now () { printf '%(%Y-%m-%dT%H:%M:%S%z)T' -1 ; }
+PS4='+ $(_iso_now) '
