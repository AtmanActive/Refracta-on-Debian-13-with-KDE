+#   Known names are mapped explicitly; unknown "@a_b_c" become "/a/b/c".
+btrfs_guess_mount () {
+	case "$1" in
+		@rootfs|@root|@)  echo "/" ;;
+		@home)            echo "/home" ;;
+		@snapshots)       echo "/.snapshots" ;;
+		@swap)            echo "/swap" ;;
+		@var)             echo "/var" ;;
+		@var_log)         echo "/var/log" ;;
+		@var_cache)       echo "/var/cache" ;;
+		@libvirt_images)  echo "/var/lib/libvirt/images" ;;
+		@tmp)             echo "/tmp" ;;
+		@opt)             echo "/opt" ;;
+		@srv)             echo "/srv" ;;
+		@*)               local _n="${1#@}" ; echo "/${_n//_//}" ;;
+		*)                echo "" ;;
+	esac
+}
+
+# load_btrfs_layout DEVICE
+#   Learn the btrfs subvolume layout of DEVICE by mounting its top level
+#   (subvolid=5) and either (1) reading the layout manifest if present
+#   (authoritative), or (2) discovering the existing subvolumes with
+#   `btrfs subvolume list` and guessing their mountpoints by convention.
+#   Populates btrfs_subvols / btrfs_subvol_mounts (sorted shallow-first so
+#   parent mounts precede children) and btrfs_root_subvol / btrfs_layout_source.
+#   Returns 0 if any subvolumes were found (=> subvol mode), 1 otherwise.
+load_btrfs_layout () {
+	local _dev="$1" _tmp _raw="" _src="default" _rc=1 _sv _mp _i
+	_tmp=$(mktemp -d)
+	mount -o subvolid=5 "$_dev" "$_tmp" 2>/dev/null || { rmdir "$_tmp"; return 1; }
+	if [[ -f "$_tmp/$btrfs_layout_manifest" ]]; then
+		_raw=$(awk -F'\t' '/^[[:space:]]*#/{next} NF<2{next} {print $1"\t"$2}' "$_tmp/$btrfs_layout_manifest")
+		_src="manifest"
+	else
+		_raw=$(btrfs subvolume list "$_tmp" 2>/dev/null | awk '{print $NF}' \
+			| while read -r _s; do
+				[[ "$_s" == */* ]] && continue   # skip nested subvolumes
+				printf '%s\t%s\n' "$_s" "$(btrfs_guess_mount "$_s")"
+			done)
+		_src="guessed"
+	fi
+	umount "$_tmp" 2>/dev/null; rmdir "$_tmp"
+
+	if [[ -n "$_raw" ]]; then
+		btrfs_subvols=(); btrfs_subvol_mounts=()
+		while IFS=$'\t' read -r _ _sv _mp; do
+			[[ -z "$_sv" || -z "$_mp" ]] && continue
+			btrfs_subvols+=("$_sv"); btrfs_subvol_mounts+=("$_mp")
+		done < <(printf '%s\n' "$_raw" | awk -F'\t' 'NF>=2 && $2!="" {d=gsub(/\//,"/",$2); print d"\t"$1"\t"$2}' | sort -n -k1,1)
+		if [[ ${#btrfs_subvols[@]} -gt 0 ]]; then
+			btrfs_root_subvol="@rootfs"
+			for _i in "${!btrfs_subvols[@]}"; do
+				[[ "${btrfs_subvol_mounts[$_i]}" == "/" ]] && btrfs_root_subvol="${btrfs_subvols[$_i]}"
+			done
+			btrfs_layout_source="$_src"
+			_rc=0
+		fi
+	fi
+	return $_rc
+}
