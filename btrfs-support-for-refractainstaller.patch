+		@snapshots)       echo "/.snapshots" ;;
+		@swap)            echo "/swap" ;;
+		@var)             echo "/var" ;;
+		@var_log)         echo "/var/log" ;;
+		@var_cache)       echo "/var/cache" ;;
+		@libvirt_images)  echo "/var/lib/libvirt/images" ;;
