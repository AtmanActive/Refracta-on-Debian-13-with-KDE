 # Fix root's path (for Buster/Beowulf and later)
 PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
 
+# ── Guided / automated btrfs helpers ─────────────────────────────────────────
+
+# Set the installer variables for a guided/automated btrfs install so the rest
+# of the flow runs non-interactively over the "Do not format" path.
+_guided_set_vars () {   # $1=esp part  $2=boot part  $3=root part
+	guided="yes"
+	esp_dev="$1"; boot_dev="$2"; install_dev="$3"
+	must_choose_esp="no"; uefi_boot="yes"; grub_dev="efi"
+	sep_boot="yes"; sep_home="no"; no_format="yes"; use_uuid="yes"
+	use_existing_swap="no"; encrypt_os="no"; encrypt_home="no"
+}
+
+# _disk_is_blank DEV  ->  0 if DEV has no partitions, no partition table, and no
+# filesystem signature (i.e. safe to treat as an empty disk).
+_disk_is_blank () {
+	local _d="$1"
+	[[ -b "$_d" ]] || return 1
+	[[ -n "$(lsblk -nr -o NAME "$_d" 2>/dev/null | tail -n +2)" ]] && return 1
+	[[ -n "$(lsblk -no PTTYPE "$_d" 2>/dev/null | tr -d '[:space:]')" ]] && return 1
+	[[ -n "$(lsblk -no FSTYPE "$_d" 2>/dev/null | tr -d '[:space:]')" ]] && return 1
+	blkid -p "$_d" >/dev/null 2>&1 && return 1
+	return 0
+}
+
+# _list_blank_disks  ->  one eligible blank whole-disk per line (excludes the
+# live boot medium and any disk that currently has mounted partitions).
+_list_blank_disks () {
+	local _n _dev
+	while read -r _n; do
+		_dev="/dev/$_n"
+		[[ "$_dev" == "$live_medium" ]] && continue
+		lsblk -nr -o MOUNTPOINT "$_dev" 2>/dev/null | grep -q . && continue
+		_disk_is_blank "$_dev" && echo "$_dev"
+	done < <(lsblk -dn -o NAME -e 7,11 2>/dev/null)
+}
+
+# guided_auto_setup
+#   Automated whole-disk btrfs install onto a BLANK disk: auto-select when there
+#   is exactly one blank disk, otherwise let the user pick among the blank disks;
+#   one confirmation; then partition via btrfs-disk-lib.sh and set the guided
+#   variables. Returns 0 on success, 1 on cancel/failure.
+guided_auto_setup () {
+	local _lib="/usr/lib/refractainstaller/btrfs-disk-lib.sh" _disk _log _feed _d
+	local -a _blanks
+	if [[ ! -d /sys/firmware/efi ]]; then
+		yad --image=gtk-dialog-error --title=$"Automated btrfs install" --center --borders=10 --button=$"OK":0 \
+		  --text=$"Automated install requires booting in UEFI mode."
+		return 1
+	fi
+	if [[ ! -f "$_lib" ]]; then
+		yad --image=gtk-dialog-error --title=$"Automated btrfs install" --center --borders=10 --button=$"OK":0 \
+		  --text=$"Missing $_lib - the btrfs disk library is not installed."
+		return 1
+	fi
+	source "$_lib"
+	if ! refracta_btrfs_check_tools 2>/tmp/refracta-tools.err ; then
+		yad --image=gtk-dialog-error --title=$"Automated btrfs install" --center --borders=10 --button=$"OK":0 \
+		  --text=$"Required tools are missing:\n$(cat /tmp/refracta-tools.err)\n\nInstall: gdisk dosfstools e2fsprogs btrfs-progs"
+		return 1
+	fi
+
+	mapfile -t _blanks < <(_list_blank_disks)
+	if [[ ${#_blanks[@]} -eq 0 ]]; then
+		yad --image=gtk-dialog-error --title=$"Automated btrfs install" --center --borders=10 --button=$"OK":0 \
+		  --text=$"No blank disk was found. Free up a disk, or restart and choose the custom option."
+		return 1
+	elif [[ ${#_blanks[@]} -eq 1 ]]; then
+		_disk="${_blanks[0]}"
+	else
+		_feed=$(mktemp)
+		for _d in "${_blanks[@]}"; do
+			printf '%s\n%s\n%s\n' "$_d" "$(lsblk -dn -o SIZE "$_d" 2>/dev/null)" "$(lsblk -dn -o MODEL "$_d" 2>/dev/null)" >> "$_feed"
+		done
+		_disk=$(yad --list --title=$"Select blank disk" --center --borders=10 --width=620 --height=280 \
+			--separator="" --print-column=1 --column $"Device" --column $"Size" --column $"Model" \
+			--text=$"More than one blank disk was found. Choose the disk to use (it will be ERASED)." \
+			--button=$"Cancel":1 --button=$"Continue":0 < "$_feed")
+		rm -f "$_feed"
+		[[ -n "$_disk" && -b "$_disk" ]] || return 1
+	fi
+
+	yad --image=gtk-dialog-warning --title=$"Automated btrfs install" --center --borders=10 \
+	  --button=$"Cancel":1 --button=$"ERASE and install":0 \
+	  --text=$"Automated install will ERASE the following disk and set it up with an EFI + /boot + btrfs subvolume layout:\n\n        $_disk\n\nALL DATA ON $_disk WILL BE LOST. Continue?"
+	[[ $? -eq 0 ]] || return 1
+
+	_log="/tmp/refracta-guided-disk.log"
+	if ! refracta_btrfs_make_layout "$_disk" >"$_log" 2>&1 ; then
+		yad --text-info --title=$"Automated btrfs install FAILED" --center --borders=10 \
+		  --fontname="Monospace" --width=760 --height=480 --button=$"OK":0 < "$_log"
+		return 1
+	fi
+	_guided_set_vars "$(refracta_part_name "$_disk" 1)" "$(refracta_part_name "$_disk" 2)" "$(refracta_part_name "$_disk" 3)"
+	yad --text-info --title=$"btrfs layout created" --center --borders=10 \
+	  --fontname="Monospace" --width=760 --height=420 --button=$"Continue":0 < "$_log"
+	return 0
+}
+
+# ── Installation type: automated (blank disk) vs custom (all options) ─────────
+auto_mode="no"
+while true ; do
+	yad --title=$"Installation type" --center --borders=10 --width=680 \
+	  --button=$"Automated btrfs install":0 --button=$"Custom - all options":1 --button=$"Exit":2 \
+	  --text=$"How would you like to install?
+
+ * Automated btrfs install
+   For a machine with a BLANK disk. Wipes one blank disk and creates an
+   EFI + /boot + btrfs-subvolume layout automatically, then installs.
+   No partitioning and no expert questions. Requires a UEFI boot.
+
+ * Custom - all options
+   For existing or complex disk layouts. You partition the disk (or use
+   'Do not format' with a disk you prepared) and see every expert option."
+	case $? in
+		0)	if [[ ! -d /sys/firmware/efi ]]; then
+				yad --image=gtk-dialog-error --title=$"Automated btrfs install" --center --borders=10 --button=$"OK":0 \
+				  --text=$"Automated install requires booting in UEFI mode.\n\nUse 'Custom - all options', or reboot in UEFI mode."
+			elif [[ -z "$(_list_blank_disks)" ]]; then
+				yad --image=gtk-dialog-error --title=$"Automated btrfs install" --center --borders=10 --button=$"OK":0 \
+				  --text=$"No blank disk was detected (the live medium and mounted disks are excluded).\n\nUse 'Custom - all options', or free up a disk and try again."
+			else
+				auto_mode="yes"; break
+			fi ;;
+		1)	auto_mode="no"; break ;;
+		*)	exit 0 ;;
+	esac
+done
