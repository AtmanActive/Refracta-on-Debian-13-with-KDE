+# First screen: disk-state detection + warning, BEFORE anything else.
+# Refracta installs the running live system onto a disk you prepare; some actions
+# here (especially the guided "Auto-create btrfs layout" option) erase a whole
+# disk. Detect and flag the live boot medium so the user never targets it.
+live_medium=""
+for _m in /run/live/medium /lib/live/mount/medium /usr/lib/live/mount/medium ; do
+	[[ -d "$_m" ]] || continue
+	_src=$(findmnt -n -o SOURCE --target "$_m" 2>/dev/null | head -1)
+	[[ -n "$_src" ]] || continue
+	_pk=$(lsblk -no PKNAME "$_src" 2>/dev/null | head -1)
+	[[ -n "$_pk" ]] && live_medium="/dev/$_pk" || live_medium="$_src"
+	break
+done
+
+{
