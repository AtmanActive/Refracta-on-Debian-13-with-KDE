yad --image="$REFRACTA_ICON" --title="$window_title" --center --borders=10 --text=$" Installation complete. \n\n You may now reboot into the new system.\n\n Remember to remove your installation media.\n\n $_elapsed_msg\n" --width=500 --button=$"OK":0

# Stop dual logging and do final sync
if [[ -n "$_log_tail_pid" ]]; then
	kill "$_log_tail_pid" 2>/dev/null
	wait "$_log_tail_pid" 2>/dev/null
fi
# Final sync of error log to target
[[ -n "$_target_error_log" ]] && cp "$error_log" "$_target_error_log" 2>/dev/null

# copy error log to installation now before calling cleanup function
cp "$error_log" /target/home/"$newusername"/
chown 1000:1000 /target/home/"$newusername"/"${error_log##*/}"
cleanup

exit 0
