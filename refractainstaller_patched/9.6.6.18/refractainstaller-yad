# --- total elapsed-time reporting (purely cosmetic) ---
# Record when the script started so the final "all done" dialog can report how
# long the whole run took - every dialog and copy, from launch to finish. Best-
# effort: if the start time was never captured the sentence is simply omitted.
REFRACTA_START_EPOCH=$(date +%s)
refracta_plural() {  # <count> <singular-noun> -> "1 noun" or "N nouns"
	if (( $1 == 1 )); then printf '%d %s' "$1" "$2"; else printf '%d %ss' "$1" "$2"; fi
}
refracta_elapsed_sentence() {
	local t d h m s
	[[ $REFRACTA_START_EPOCH =~ ^[0-9]+$ ]] || return 0
	t=$(( $(date +%s) - REFRACTA_START_EPOCH ))
	(( t > 0 )) || t=0
	d=$(( t / 86400 ))
	h=$(( t % 86400 / 3600 ))
	m=$(( t % 3600 / 60 ))
	s=$(( t % 60 ))
	if   (( d > 0 )); then printf 'This operation took %s, %s, %s, %s.' "$(refracta_plural "$d" day)" "$(refracta_plural "$h" hour)" "$(refracta_plural "$m" minute)" "$(refracta_plural "$s" second)"
	elif (( h > 0 )); then printf 'This operation took %s, %s, %s.' "$(refracta_plural "$h" hour)" "$(refracta_plural "$m" minute)" "$(refracta_plural "$s" second)"
	elif (( m > 0 )); then printf 'This operation took %s, %s.' "$(refracta_plural "$m" minute)" "$(refracta_plural "$s" second)"
	else                   printf 'This operation took %s.' "$(refracta_plural "$s" second)"
	fi
}


