# Install (or not) grub


 
# configure_resume UUID [OFFSET]
#   Configure the installed system to resume from hibernation. UUID is the block
#   device that holds the swap: the filesystem device for a swapfile, or the swap
#   partition itself. OFFSET is the swapfile's resume offset (empty for a swap
#   partition). Tells the initramfs which device to resume from and adds
#   resume=/resume_offset= to the kernel command line via GRUB. No-op if no swap.
configure_resume () {
	local _uuid="$1" _off="$2" _params _grub="/target/etc/default/grub"
	[[ -z "$_uuid" ]] && return 0
	_params="resume=UUID=$_uuid"
	[[ -n "$_off" ]] && _params="$_params resume_offset=$_off"
	mkdir -p /target/etc/initramfs-tools/conf.d
	echo "RESUME=UUID=$_uuid" > /target/etc/initramfs-tools/conf.d/resume
	if [[ -f "$_grub" ]] && ! grep -q 'resume=UUID=' "$_grub" ; then
		if grep -q '^GRUB_CMDLINE_LINUX_DEFAULT=' "$_grub" ; then
			sed -i "s|^\(GRUB_CMDLINE_LINUX_DEFAULT=\"[^\"]*\)\"|\1 $_params\"|" "$_grub"
		else
			echo "GRUB_CMDLINE_LINUX_DEFAULT=\"$_params\"" >> "$_grub"
		fi
	fi
}


install_grub () {
# Setup GRUB
echo $"Setting up grub bootloader.. Please wait.."

# Configure hibernation resume (no-op if there is no swap / encrypted root).
configure_resume "$resume_uuid" "$resume_offset"

# If /boot is separate partition, mount it in the chroot for grub — but only if
# it isn't already mounted. With EFI + a separate /boot, the ESP-setup phase
# already mounts $boot_dev at /target/boot (with the ESP under it at
# /target/boot/efi). Re-mounting here stacks a second /boot that SHADOWS
# /boot/efi inside the chroot, making grub-install fail with "cannot find EFI
# directory". The findmnt guard skips the redundant remount in that case while
# still mounting /boot for the BIOS / no-ESP path.
if [[ -n $boot_dev ]] ; then
    if ! findmnt /target/boot >/dev/null 2>&1 ; then
        chroot /target mount $boot_dev /boot 2>/dev/null || true
    fi
fi

# Verify ESP is mounted for EFI install before running grub-install
if [[ $grub_dev = "efi" ]] ; then
	if ! findmnt /target/boot/efi >/dev/null 2>&1 ; then
		yad --image="gtk-dialog-error" --title=$"Error" --center --borders=10 \
		  --button=$"Exit":0 \
		  --text=$"EFI partition is not mounted at /target/boot/efi\n\nCannot install GRUB bootloader. Aborting."
		exit 1
	fi
fi


# If grub is installed to a partition, we need to know if it's grub-pc
# or grub-legacy/grub-gfx to handle it properly.
if [[ -n $grub_partition ]] ; then
	if [[ $grubversion != "grub-pc" ]] ; then

		# isolate the device (sdx) letter then use tr like this to translate to the right number for grub
		GRUBDEVICENUM=$(echo $grub_partition |sed 's:/dev/sd::' |sed 's:[0-9]::'g |tr '[a-j]' '[0-9]')

		# isolate the partition number
		INSTALLPARTNUM=$(echo $grub_partition |sed 's:/dev/sd::'|sed 's:[a-z]::')

		# and reduce it by 1 for grub
		GRUBPARTNUM=$(expr $INSTALLPARTNUM - 1)

		# finally get the finished grub root syntax
		GRUBROOT="(hd$GRUBDEVICENUM,$GRUBPARTNUM)"


		chroot /target grub-install $grub_partition
		grub --batch <<EOF
		root $GRUBROOT
		setup $GRUBROOT
		quit
EOF

	else
		error_message=$"grub-install failed."
		chroot /target grub-install --recheck --no-floppy --force $grub_partition >> "$error_log" ; check_exit
	fi

elif [[ $grub_dev = "efi" ]] ; then
	chroot /target grub-install ${efi_name_opt} ${media_opt} >> "$error_log"; check_exit

elif [[ -n $grub_dev ]]; then
    echo -e $"\n Installing the boot loader...\n"
    chroot /target grub-install $grub_dev >> "$error_log"; check_exit
fi

chroot /target update-grub ; check_exit

error_message=""
}


