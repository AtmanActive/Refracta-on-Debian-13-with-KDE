# guided_btrfs_setup
#   Whole-disk guided btrfs install. Pick a disk, type-to-confirm, then create
#   ESP + /boot + btrfs(subvolumes) + manifest via btrfs-disk-lib.sh, and pre-set
#   the installer variables so the rest of the install runs non-interactively over
#   the "Do not format" path (which learns the manifest we just wrote).
#   Returns 0 on success (caller should proceed), 1 if cancelled or it failed.
guided_btrfs_setup () {
	local _lib="/usr/lib/refractainstaller/btrfs-disk-lib.sh"
	local _disk _confirm _p1 _p2 _p3 _log _feed _name _size _rest _dev

	# Guided btrfs setup does not support encryption: the subvolume + swapfile +
	# hibernation layout is not built on LUKS, and resume-from-encrypted-swap needs
	# setup this installer does not perform. Refuse rather than half-configure.
	if [[ "$encrypt_os" = "yes" || "$encrypt_home" = "yes" ]]; then
		yad --image=gtk-dialog-error --title=$"Auto-create btrfs layout" --center --borders=10 --button=$"OK":0 \
		  --text=$"Guided btrfs setup cannot be combined with encryption.\n\nThe btrfs subvolume + swapfile + hibernation layout is not set up on an encrypted (LUKS) device, and resuming from encrypted swap needs extra configuration this installer does not perform.\n\n  - To use guided btrfs: go back and UNCHECK the encryption options.\n  - To use encryption: partition manually and choose an ext filesystem."
		return 1
	fi

	# Guided mode builds an EFI layout; require a UEFI boot.
	if [[ ! -d /sys/firmware/efi ]]; then
		yad --image=gtk-dialog-error --title=$"Auto-create btrfs layout" --center --borders=10 --button=$"OK":0 \
		  --text=$"This guided setup creates an EFI layout, but the live system was not booted in UEFI mode.\n\nReboot in UEFI mode, or partition manually."
		return 1
	fi
	if [[ ! -f "$_lib" ]]; then
		yad --image=gtk-dialog-error --title=$"Auto-create btrfs layout" --center --borders=10 --button=$"OK":0 \
		  --text=$"Missing $_lib\n\nThe btrfs disk library is not installed; cannot continue."
		return 1
	fi
	source "$_lib"
	if ! refracta_btrfs_check_tools 2>/tmp/refracta-tools.err ; then
		yad --image=gtk-dialog-error --title=$"Auto-create btrfs layout" --center --borders=10 --button=$"OK":0 \
		  --text=$"Required tools are missing:\n$(cat /tmp/refracta-tools.err)\n\nInstall: gdisk dosfstools e2fsprogs btrfs-progs"
		return 1
	fi

	# Build eligible disks: exclude the live medium and any disk with mounted
	# partitions. Emit yad --list cells (device, size, model) into a feed file.
	_feed=$(mktemp)
	while read -r _name _size _rest; do
		_dev="/dev/$_name"
		[[ "$_dev" == "$live_medium" ]] && continue
		lsblk -nr -o MOUNTPOINT "$_dev" 2>/dev/null | grep -q . && continue
		printf '%s\n%s\n%s\n' "$_dev" "$_size" "${_rest:-disk}" >> "$_feed"
	done < <(lsblk -dn -o NAME,SIZE,MODEL -e 7,11 2>/dev/null)

	if [[ ! -s "$_feed" ]]; then
		rm -f "$_feed"
		yad --image=gtk-dialog-error --title=$"Auto-create btrfs layout" --center --borders=10 --button=$"OK":0 \
		  --text=$"No eligible disk found (the live medium and any mounted disks are excluded).\n\nUnmount disks or use GParted, then try again."
		return 1
	fi

	_disk=$(yad --list --title=$"Select disk to ERASE" --center --borders=10 --width=620 --height=300 \
		--separator="" --print-column=1 --column $"Device" --column $"Size" --column $"Model" \
		--text=$"Select the disk to partition. ITS ENTIRE CONTENTS WILL BE DESTROYED.\nThe live boot medium and mounted disks are not listed." \
		--button=$"Cancel":1 --button=$"Continue":0 < "$_feed")
	local _rc=$?
	rm -f "$_feed"
	[[ $_rc -eq 0 && -n "$_disk" && -b "$_disk" ]] || return 1

	_p1=$(refracta_part_name "$_disk" 1); _p2=$(refracta_part_name "$_disk" 2); _p3=$(refracta_part_name "$_disk" 3)

	# Type-to-confirm: the user must type the exact device path.
	_confirm=$(yad --entry --title=$"Confirm destruction" --center --borders=10 --width=560 \
		--button=$"Cancel":1 --button=$"ERASE and create":0 \
		--text=$"About to ERASE $_disk and create:\n   $_p1  1 GiB  FAT32  /boot/efi\n   $_p2  1 GiB  ext4   /boot\n   $_p3  rest   btrfs  / (subvolumes: ${REFRACTA_BTRFS_LAYOUT[*]%%:*})\n\nALL DATA ON $_disk WILL BE LOST.\nType the device path  $_disk  to confirm:")
	[[ $? -eq 0 ]] || return 1
	if [[ "$_confirm" != "$_disk" ]]; then
		yad --image=gtk-dialog-error --title=$"Confirm destruction" --center --borders=10 --button=$"OK":0 \
		  --text=$"What you typed did not match $_disk. Aborting - nothing was changed."
		return 1
	fi

	# Do it (runs a few seconds), then show the log.
	_log="/tmp/refracta-guided-disk.log"
	if ! refracta_btrfs_make_layout "$_disk" >"$_log" 2>&1 ; then
		yad --text-info --title=$"Auto-create btrfs layout FAILED" --center --borders=10 \
		  --fontname="Monospace" --width=760 --height=480 --button=$"OK":0 < "$_log"
		return 1
	fi

	# Pre-set installer variables so the rest of the install is non-interactive
	# and uses the manifest we just wrote (Do-not-format -> load_btrfs_layout).
	_guided_set_vars "$_p1" "$_p2" "$_p3"

	yad --text-info --title=$"btrfs layout created" --center --borders=10 \
	  --fontname="Monospace" --width=760 --height=420 --button=$"Continue":0 < "$_log"
	return 0
}


partition_disk () {
if [ -n "$gpt_list" ] || [ "$uefi_boot" = yes ] ; then
	cli_partition_tool="gdisk"
else
	cli_partition_tool="cfdisk"
fi

while true ; do
yad --title=$"Partitioning" --button=$"Run GParted":0 --button=$"Run $cli_partition_tool":1 \
    --width=780 --button=$"Explain btrfs subvolumes":4 --button=$"Auto-create btrfs layout":5 \
    --button=$"Skip this step":2 --button=$"Exit":3 --center --borders=10 \
    --text=$"  You need to have at least one partition ready for the installation, plus one for each separate
  partition that you chose. If you already have the partition(s) ready, you can skip this step.

  Installing onto an existing btrfs subvolume layout? Click \"Explain btrfs subvolumes\".

  Or let the installer build it for you: \"Auto-create btrfs layout\" partitions a whole
  disk into ESP + /boot + btrfs subvolumes and writes the manifest. THIS ERASES THAT DISK.

  Run the partitioner now?"

	ans="$?"
