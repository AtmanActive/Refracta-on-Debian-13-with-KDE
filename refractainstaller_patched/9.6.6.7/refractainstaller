	echo -e $"\n Making a swap file...\n"
	# Default swapfile location (non-btrfs and plain btrfs).
	swapfile_fstab="/swapfile"
	swapfile_target="/target/swapfile"
	# On btrfs, if the layout has a dedicated @swap subvolume, put the swapfile
	# there (kept out of root snapshots).
	if [[ "$fs_type_os" == "btrfs" && "$btrfs_mode" == "subvol" ]]; then
		for _idx in "${!btrfs_subvols[@]}"; do
			if [[ "${btrfs_subvols[$_idx]}" == "@swap" ]]; then
				swapfile_fstab="${btrfs_subvol_mounts[$_idx]}/swapfile"
				swapfile_target="/target${btrfs_subvol_mounts[$_idx]}/swapfile"
				break
			fi
		done
	fi
	mkdir -p "$(dirname "$swapfile_target")"
	# A btrfs swapfile MUST be NoCoW or swapon fails ("swapfile has holes").
	# chattr +C only takes effect on an empty file, so set it before writing.
	# (Only btrfs needs this; other filesystems don't.)
	if [[ "$fs_type_os" == "btrfs" ]]; then
		rm -f "$swapfile_target"
		truncate -s 0 "$swapfile_target"
		chattr +C "$swapfile_target" 2>/dev/null
	fi
	# Size the swapfile to match the target's RAM (rounded up to a whole GiB) so
	# it is large enough for hibernation. Applies to EVERY filesystem; the stock
	# 256 MiB default rounds to 0 GiB in `free -g` and is useless on a desktop.
	# Falls back to the configured size if RAM can't be read.
	swap_bs="$swapfile_blocksize"
	swap_count="$swapfile_count"
	_mem_mib=$(awk '/^MemTotal:/ {print int($2/1024)}' /proc/meminfo 2>/dev/null)
	if [[ -n "$_mem_mib" && "$_mem_mib" -ge 1 ]]; then
		swap_bs="1M"
		swap_count=$(( ( (_mem_mib + 1023) / 1024 ) * 1024 ))
		echo -e $"\n Sizing swapfile to ${swap_count} MiB to match RAM (${_mem_mib} MiB)...\n"
	fi
	dd if=/dev/zero of="$swapfile_target" bs="$swap_bs" count="$swap_count" ; check_exit
	chmod 600 "$swapfile_target"
	mkswap "$swapfile_target" ; check_exit
