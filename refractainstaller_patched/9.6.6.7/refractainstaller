# configure_resume UUID [OFFSET]
#   Configure the installed system to resume from hibernation. UUID is the block
#   device that holds the swap: the filesystem device for a swapfile, or the swap
#   partition itself. OFFSET is the swapfile's resume offset (empty for a swap
#   partition). Tells the initramfs which device to resume from and adds
#   resume=/resume_offset= to the kernel command line via GRUB. No-op if no swap.
configure_resume () {
	local _uuid="$1" _off="$2" _params _grub="/target/etc/default/grub"
	[[ -z "$_uuid" ]] && return 0
	_params="resume=UUID=$_uuid"
	[[ -n "$_off" ]] && _params="$_params resume_offset=$_off"
	mkdir -p /target/etc/initramfs-tools/conf.d
	echo "RESUME=UUID=$_uuid" > /target/etc/initramfs-tools/conf.d/resume
	if [[ -f "$_grub" ]] && ! grep -q 'resume=UUID=' "$_grub" ; then
		if grep -q '^GRUB_CMDLINE_LINUX_DEFAULT=' "$_grub" ; then
			sed -i "s|^\(GRUB_CMDLINE_LINUX_DEFAULT=\"[^\"]*\)\"|\1 $_params\"|" "$_grub"
		else
			echo "GRUB_CMDLINE_LINUX_DEFAULT=\"$_params\"" >> "$_grub"
		fi
	fi
	echo -e $"\n Hibernation: resume=UUID=$_uuid ${_off:+resume_offset=$_off}\n"
}


install_grub () {
# Setup GRUB
