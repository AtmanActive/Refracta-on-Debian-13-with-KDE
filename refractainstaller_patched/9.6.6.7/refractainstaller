# Configure hibernation resume (no-op if there is no swap / encrypted root).
configure_resume "$resume_uuid" "$resume_offset"

# Verify ESP is mounted for EFI install before running grub-install
if [[ $grub_dev = "efi" ]] ; then
	if ! findmnt /target/boot/efi >/dev/null 2>&1 ; then
		echo $"
 ERROR: EFI partition is not mounted at /target/boot/efi
 Cannot install GRUB bootloader. Aborting.
"
		exit 1
	fi
fi


