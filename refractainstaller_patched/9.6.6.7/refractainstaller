	# ($install_dev). Record the resume device UUID + the swapfile's offset.
	# Skipped for encrypted root (resuming from encrypted swap needs more setup).
	if [[ "$encrypt_os" != "yes" ]]; then
		if [[ "$fs_type_os" == "btrfs" ]]; then
			resume_offset=$(btrfs inspect-internal map-swapfile -r "$swapfile_target" 2>/dev/null)
		else
			resume_offset=$(filefrag -v "$swapfile_target" 2>/dev/null | awk '$1=="0:"{o=$4; sub(/\.\./,"",o); print o; exit}')
		fi
		# Only enable resume if we actually obtained the swapfile's offset.
		[[ -n "$resume_offset" ]] && resume_uuid=$(blkid -s UUID -o value "$install_dev" 2>/dev/null)
	fi
fi

