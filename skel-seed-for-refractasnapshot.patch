+
+	add_extras
+	set_boot_options
+
+	if [[ $edit_boot_menu = "yes" ]] ; then
+		edit_boot_menus
+	fi
+
+	squash_filesystem
+	make_iso_fs
+	cleanup
+	final_message
+}
